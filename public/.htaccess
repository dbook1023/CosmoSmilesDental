# Apache configuration for public directory
# Handles URL rewriting and additional security layers

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Force HTTPS (optional - uncomment if you have an SSL certificate)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove .php extension from URLs
    # This allows you to use URLs like 'domain.com/about' instead of 'domain.com/about.php'
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^([^\.]+)$ $1.php [NC,L]
    
    # Optional: Custom 404 Page
    # ErrorDocument 404 /404.php
</IfModule>

# Security: Deny access to include files and templates directly
<FilesMatch "-(includes|header|footer|sidebar|common|nav|modals|styles|scripts)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>

# Security: Deny access to hidden files
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>

# Disable directory listing
Options -Indexes

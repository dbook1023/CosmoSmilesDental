# Cosmo Smiles Dental - Universal Hosting Redirect
<IfModule mod_rewrite.c>
    RewriteEngine On
    # RewriteBase /

    # 1. Prevent infinite loops
    RewriteCond %{ENV:REDIRECT_STATUS} 200
    RewriteRule ^ - [L]

    # 2. Redirect root to public/
    RewriteRule ^$ public/index.php [L]

    # 3. Handle all other internal requests
    # Only rewrite if not already in public folder and not a physical file in root
    RewriteCond %{REQUEST_URI} !/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

Options -Indexes
